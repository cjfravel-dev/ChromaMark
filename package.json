{
  "name": "chromamark",
  "version": "0.4.0",
  "private": true,
  "description": "ChromaMark — a lean rich-markup for agent-to-human communication. CommonMark + GFM plus colored blocks, colored pills, and collapsible sections.",
  "license": "MIT",
  "author": "cjfravel-dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjfravel-dev/ChromaMark.git"
  },
  "workspaces": [
    "packages/renderer",
    "packages/cli",
    "packages/conformance",
    "packages/vscode"
  ],
  "scripts": {
    "test": "npm test --workspace @chromamark/renderer",
    "test:eval": "node --test eval/test/*.test.js",
    "test:scripts": "node --test scripts/*.test.mjs docs/playground/*.test.mjs",
    "coverage": "node scripts/coverage.mjs",
    "eval": "node eval/run.js",
    "build:site": "node scripts/build-site.mjs",
    "build:readme": "node scripts/build-readme.mjs",
    "build:conformance": "node scripts/build-conformance-kit.mjs",
    "lint": "eslint ."
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "typescript": "^5.9.3"
  }
}
