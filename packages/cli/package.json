{
  "name": "@chromamark/cli",
  "version": "0.2.1",
  "description": "ChromaMark command-line tool — compile .cm to self-contained HTML, render to a color terminal, or lint.",
  "license": "MIT",
  "author": "cjfravel-dev",
  "homepage": "https://github.com/cjfravel-dev/ChromaMark#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjfravel-dev/ChromaMark.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/cjfravel-dev/ChromaMark/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "bin": {
    "chromamark": "./bin/chromamark.js"
  },
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "test": "node --test"
  },
  "keywords": [
    "chromamark",
    "markdown",
    "cli",
    "static-site",
    "html"
  ],
  "dependencies": {
    "@chromamark/renderer": "^0.3.1"
  }
}
