{
  "name": "chromamark-vscode",
  "displayName": "ChromaMark",
  "description": "Live preview, syntax highlighting, lint diagnostics, and quick fixes for ChromaMark.",
  "version": "0.2.0",
  "publisher": "chromamark",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjfravel-dev/ChromaMark.git",
    "directory": "packages/vscode"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "chromamark",
    "markdown",
    "callout",
    "admonition",
    "preview",
    "lint",
    "quick fixes"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node build.mjs",
    "vscode:prepublish": "node build.mjs",
    "package": "vsce package --no-dependencies",
    "test": "node --test"
  },
  "contributes": {
    "commands": [
      {
        "command": "chromamark.setOpenMode",
        "title": "Set Open Mode...",
        "category": "ChromaMark"
      }
    ],
    "languages": [
      {
        "id": "markdown",
        "extensions": [
          ".cm"
        ]
      }
    ],
    "grammars": [
      {
        "scopeName": "markup.chromamark.injection",
        "path": "./syntaxes/chromamark.injection.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ]
      }
    ],
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./media/chromamark.css",
      "./media/toc.css"
    ],
    "markdown.previewScripts": [
      "./media/toc.js"
    ],
    "configuration": {
      "title": "ChromaMark",
      "properties": {
        "chromamark.cm.openMode": {
          "type": "string",
          "enum": [
            "preview",
            "sourceAndPreview",
            "source"
          ],
          "enumDescriptions": [
            "Open the rendered preview only (reopens the source editor as the preview).",
            "Open the source editor with the rendered preview beside it.",
            "Open the source editor only (no automatic preview)."
          ],
          "default": "preview",
          "markdownDescription": "How ChromaMark (`.cm`) files open."
        },
        "chromamark.md.openMode": {
          "type": "string",
          "enum": [
            "preview",
            "sourceAndPreview",
            "source"
          ],
          "enumDescriptions": [
            "Open the rendered preview only (reopens the source editor as the preview).",
            "Open the source editor with the rendered preview beside it.",
            "Open the source editor only (no automatic preview)."
          ],
          "default": "sourceAndPreview",
          "markdownDescription": "How Markdown (`.md`) files open."
        }
      }
    }
  },
  "dependencies": {
    "@chromamark/renderer": "^0.4.0"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.24.2",
    "jsdom": "^26.1.0",
    "ovsx": "1.0.2"
  }
}
